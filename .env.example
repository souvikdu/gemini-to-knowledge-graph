# ── Gemini Web API (for extract_gemini_chat.py) ──
# Get these from gemini.google.com cookies (__Secure-1PSID, __Secure-1PSIDTS)
# or set them to your session values.
GEMINI_1PSID=
GEMINI_1PSIDTS=

# ── LLM API (for classify_chats.py) ──
# Leave empty for local models (e.g. llama-server). Set for cloud APIs.
LLM_API_KEY=
